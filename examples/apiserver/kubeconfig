apiVersion: v1
kind: Config
clusters:
  - cluster:
      server: https://localhost:6443
      insecure-skip-tls-verify: true
    name: local-apiserver
users:
  - name: anonymous
    user:
      token: anonymous
contexts:
  - context:
      cluster: local-apiserver
      user: anonymous
    name: local
current-context: local
